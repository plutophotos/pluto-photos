{
  "name": "pluto-photos",
  "version": "2.3.23",
  "description": "A powerful desktop photo library manager with face detection, smart albums, map view, and cloud import.",
  "main": "./out/main/index.js",
  "author": "Pluto Photos",
  "homepage": "https://plutophotos.com",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:video-editor-web": "vite build --config vite.video-editor.config.ts",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win:dir": "npm run build && electron-builder --win --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac:x64:dir": "npm run build && electron-builder --mac --dir --x64",
    "build:mac:arm64:dir": "npm run build && electron-builder --mac --dir --arm64",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux:dir": "npm run build && electron-builder --linux --dir",
    "build:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3,sharp"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/source-code-pro": "^5.2.7",
    "@napi-rs/canvas": "^0.1.95",
    "ag-psd": "^30.1.0",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.3.9",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "onnxruntime-node": "^1.24.2",
    "pdfjs-dist": "^5.4.624",
    "selfsigned": "^5.5.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vladmandic/face-api": "^1.7.15",
    "chokidar": "^5.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "exif-reader": "^2.0.3",
    "form-data": "^4.0.5",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-vue-next": "^0.574.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "virtua": "^0.48.5",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  },
  "overrides": {
    "@electron/osx-sign": {
      "isbinaryfile": "^5.0.4"
    }
  }
}
