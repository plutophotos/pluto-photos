# ============================================================
# Pluto Photos — Environment Configuration
# ============================================================
# Rename this file to .env and customize the values below.
# Only UPLOAD_LOCATION and PLUTO_WEB_PASSWORD are required.
# ============================================================

# The location where your photos are stored on the HOST machine
UPLOAD_LOCATION=/path/to/your/photos

# Web login password (REQUIRED on first run)
PLUTO_WEB_PASSWORD=changeme

# Web login username
PLUTO_WEB_USERNAME=admin

# Port for the web interface (HTTPS)
# PLUTO_PORT=3456

# Minutes between automatic library re-scans (0 = disabled)
# PLUTO_SCAN_INTERVAL=60

# Log level: debug, info, warn, error
# PLUTO_LOG_LEVEL=info
